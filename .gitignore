```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# IDEs
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# Testing
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyre/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# Model Checkpoints
# =========================
*.pt
*.pth
*.ckpt
*.onnx
*.safetensors

# =========================
# Audio / Video
# =========================
*.wav
*.mp3
*.mp4
*.webm
*.mkv
*.avi
*.mov

# =========================
# Temporary Files
# =========================
tmp/
temp/
cache/
*.tmp
transcript.txt

# =========================
# SQLite
# =========================
*.db
*.sqlite3

# =========================
# Secrets
# =========================
secrets.json
credentials.json

# =========================
# Misc
# =========================
*.bak
*.orig
```
